# Admin
# Password for the /admin route (HTTP Basic Auth). Required.
ADMIN_PASSWORD=change-me

# Path to the directory where reference images are stored.
# Defaults to ./static/references (project root) for local development.
# In production, set this to a persistent directory outside the deployment folder
# so uploads survive re-deployments. Copy the existing images there on first deploy.
REFERENCES_DIR=/var/www/uploads/references

# Path to the references data JSON file.
# Defaults to ./data/references.json (project root).
# In production, set this to a persistent path outside the deployment folder.
REFERENCES_DATA_FILE=/var/www/data/references.json

# Nodemailer / SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=secret
MAIL_FROM="Insektenschutz Rhein-Sieg <noreply@insektenschutz-rhein-sieg.de>"
MAIL_TO=info@insektenschutz-rhein-sieg.de
