# Admin
# Password for the /admin route (HTTP Basic Auth). Required.
ADMIN_PASSWORD=change-me

# Local dev only: images live in static/references during development.
# In production the default (data/references relative to CWD) is used automatically
# and is preserved across deploys - no need to set this variable on the server.
REFERENCES_DIR=static/references

# Nodemailer / SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=secret
MAIL_FROM="Insektenschutz Rhein-Sieg <noreply@insektenschutz-rhein-sieg.de>"
MAIL_TO=info@insektenschutz-rhein-sieg.de
